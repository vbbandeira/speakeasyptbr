# Copy to .env and fill in. Never commit .env.

# ─── ElevenLabs ─────────────────────────────────────────────────
# Creator plan ($22/mo). Profile → API Keys
ELEVENLABS_API_KEY=

# Voice IDs (from Voice Lab after cloning, or marketplace)
# See manifests/<product>.yaml to see which voices each product uses.

# Arí (clone) — primary female Portuguese voice for all products
ELEVENLABS_VOICE_ARI_PT=

# Bandeira (clone) — male Portuguese voice for dialogues/Speaker B
ELEVENLABS_VOICE_BANDEIRA_PT=

# Fallback marketplace voices (if clones drift)
ELEVENLABS_VOICE_VALENTINA_PT=
ELEVENLABS_VOICE_FERNANDA_PT=
ELEVENLABS_VOICE_ANTONIO_PT=

# Model (don't change unless you know why)
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ─── Output format defaults (per-product overrides in manifests) ─
AUDIO_SAMPLE_RATE=44100
AUDIO_CHANNELS=1
AUDIO_FORMAT=mp3
AUDIO_NORMALIZE_LUFS=-16
